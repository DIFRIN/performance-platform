#!/usr/bin/env bash
# =============================================================================
# prepare-commit-msg — Préfixe automatiquement le message de commit avec
# l'Issue active depuis progress.md.
#
# Installation (une fois) :
#   cp scripts/git-hooks/prepare-commit-msg .git/hooks/prepare-commit-msg
#   chmod +x .git/hooks/prepare-commit-msg
#
# Ou via scripts/setup-hooks.sh
# =============================================================================

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"  # message | template | merge | squash | commit

# Ne pas modifier les merge commits, amends, ou fixups
if [[ "$COMMIT_SOURCE" == "merge" ]] || [[ "$COMMIT_SOURCE" == "squash" ]]; then
  exit 0
fi

# Trouver la racine du repo
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
PROGRESS_FILE="$GIT_ROOT/progress.md"

if [[ ! -f "$PROGRESS_FILE" ]]; then
  exit 0  # Pas de progress.md → laisser passer
fi

# Extraire l'Issue IN PROGRESS
ACTIVE_ISSUE=$(grep -o 'ISSUE-[0-9]\+' "$PROGRESS_FILE" \
  | head -1 2>/dev/null || true)

# Vérifier qu'elle est bien IN PROGRESS (pas juste mentionnée)
if [[ -n "$ACTIVE_ISSUE" ]]; then
  IN_PROGRESS=$(grep "$ACTIVE_ISSUE" "$PROGRESS_FILE" | grep "IN PROGRESS" | head -1)
  if [[ -z "$IN_PROGRESS" ]]; then
    ACTIVE_ISSUE=""
  fi
fi

if [[ -z "$ACTIVE_ISSUE" ]]; then
  exit 0  # Pas d'Issue active → ne pas modifier
fi

# Lire le message actuel
CURRENT_MSG=$(cat "$COMMIT_MSG_FILE")

# Si le message contient déjà une référence ISSUE-XXX → ne pas dupliquer
if echo "$CURRENT_MSG" | grep -q "ISSUE-[0-9]"; then
  exit 0
fi

# Préfixer le message avec l'Issue active
echo "[$ACTIVE_ISSUE] $CURRENT_MSG" > "$COMMIT_MSG_FILE"
